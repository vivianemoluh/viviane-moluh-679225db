# =============================================================
# .env.example — Modèle pour la production (Vercel)
# =============================================================
# Copiez ce fichier vers `.env` puis remplacez les valeurs.
# En développement sur Lovable, le `.env` est déjà géré par
# Lovable Cloud — ne le modifiez pas ici.
# Pour Vercel : ajoutez ces variables dans
# Project → Settings → Environment Variables.
# =============================================================

# --- Supabase (nouveau projet perso) -------------------------
# Client (exposées au navigateur, préfixe VITE_)
VITE_SUPABASE_URL="https://dafgpqzomhoqscjnscsw.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="votre_anon_key_ici"
VITE_SUPABASE_PROJECT_ID="dafgpqzomhoqscjnscsw"

# Serveur (SSR / server functions)
SUPABASE_URL="https://dafgpqzomhoqscjnscsw.supabase.co"
SUPABASE_PUBLISHABLE_KEY="votre_anon_key_ici"
SUPABASE_PROJECT_ID="dafgpqzomhoqscjnscsw"

# ⚠️ SECRET — ne jamais commiter, ne jamais préfixer VITE_
SUPABASE_SERVICE_ROLE_KEY="votre_service_role_key_ici"

# --- Brevo (Newsletter) --------------------------------------
# ⚠️ SECRETS — serveur uniquement
BREVO_API_KEY="xkeysib-votre_cle_ici"
BREVO_LIST_ID="3"

# --- Vercel (TanStack Start / Nitro) -------------------------
# Indique à Nitro (bundler serveur de TanStack Start) de générer
# une build compatible Vercel Edge/Serverless au moment du build.
# À définir dans Vercel → Project Settings → Environment Variables.
NITRO_PRESET="vercel"
